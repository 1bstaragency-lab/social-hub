# Copy this to .env for local development
# NEVER commit .env to git

# Port the server listens on (default: 8000)
PORT=8000

# Where SQLite DB and cookie files are stored
# Local: leave blank (defaults to /tmp/socialhub)
# Render: set to /opt/render/project/data
RUNTIME_DIR=/tmp/socialhub

# Secret key used to encrypt stored passwords at rest
# Generate a strong random value for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-me-to-something-random-in-production
