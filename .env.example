# Copy this to .env for local development
# NEVER commit .env to git

# Port the server listens on (default: 8000)
PORT=8000

# Where SQLite DB and cookie files are stored
# Local: leave blank (defaults to /tmp/socialhub)
# Render: set to /opt/render/project/data
RUNTIME_DIR=/tmp/socialhub

# Secret key used to encrypt stored passwords at rest
# Generate a strong random value for production:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=change-me-to-something-random-in-production

# Browser automation (SoundCloud login via Playwright)
# Set to false to see the browser window during login (debugging)
PLAYWRIGHT_HEADLESS=true
# Directory to persist browser session data (cookies, localStorage)
BROWSER_SESSION_DIR=./browser_sessions

# Frontend URL (for CORS)
# VITE_API_URL=http://localhost:8000/api/v1
